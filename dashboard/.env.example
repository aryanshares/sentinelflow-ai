# ─────────────────────────────────────────────────────────────────────────────
# SentinalFlow AI Dashboard — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# For Vercel deployment, set these in Project → Settings → Environment Variables.
#
# LOCAL DEVELOPMENT (default, no changes needed):
VITE_WS_URL=ws://localhost:8000/ws/stream
VITE_API_URL=http://localhost:8000

# RENDER + VERCEL PRODUCTION (replace with your Render service URL):
# VITE_WS_URL=wss://your-service-name.onrender.com/ws/stream
# VITE_API_URL=https://your-service-name.onrender.com

# ─────────────────────────────────────────────────────────────────────────────
# Gemini AI Integration
# ─────────────────────────────────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
# The key is used client-side (browser → Gemini REST API directly).
#
VITE_GEMINI_API_KEY=your_gemini_api_key_here
#
# Optional: override the Gemini model (default: gemini-2.0-flash)
# Options: gemini-2.0-flash | gemini-1.5-pro | gemini-2.5-pro
VITE_GEMINI_MODEL=gemini-2.0-flash
