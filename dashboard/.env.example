# ─────────────────────────────────────────────────────────────────────────────
# SentinalFlow AI Dashboard — Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# For Vercel deployment, set these in Project → Settings → Environment Variables.
#
# LOCAL DEVELOPMENT (default, no changes needed):
VITE_WS_URL=ws://localhost:8000/ws/stream
VITE_API_URL=http://localhost:8000

# RENDER + VERCEL PRODUCTION (replace with your Render service URL):
# VITE_WS_URL=wss://your-service-name.onrender.com/ws/stream
# VITE_API_URL=https://your-service-name.onrender.com
